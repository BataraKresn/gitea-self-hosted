# =============================================================================
# Gitea Production Environment Variables
# =============================================================================
# IMPORTANT: Copy this file to .env and replace ALL placeholder values.
# Never commit the real .env to version control.
#
# Generate secure secrets with:
#   openssl rand -base64 48      # for SECRET_KEY / INTERNAL_TOKEN
#   openssl rand -base64 32      # for JWT_SECRET / LFS_JWT_SECRET
#   openssl rand -hex 32         # alternative hex format
# =============================================================================

# =============================
# General
# =============================
TZ=Asia/Jakarta
COMPOSE_PROJECT_NAME=gitea

# =============================
# SSH port mapping
# =============================
# Git SSH port exposed on the HOST (users clone via this port).
# Recommended: 2222 so host's own SSH stays on 22.
# If you move host SSH to 2222 and want seamless git@domain:user/repo.git,
# set this to 22 and update firewall accordingly.
GITEA_SSH_BIND_IP=0.0.0.0
GITEA_SSH_PORT=2222

# =============================
# Gitea server identity
# =============================
GITEA_DOMAIN=git.company.id
GITEA_ROOT_URL=https://git.company.id/
# SSH_DOMAIN is the host users put in clone URLs.
# If SSH port is 22: git@git.company.id:user/repo.git
# If SSH port is 2222: ssh://git@git.company.id:2222/user/repo.git
GITEA_SSH_DOMAIN=git.company.id

# =============================
# Reverse proxy (Nginx → Gitea)
# =============================
# Number of reverse proxy hops between client and Gitea (usually 1 for Nginx)
GITEA_REVERSE_PROXY_LIMIT=1
# Nginx container IP or subnet – only trust headers from this source
# Use 172.20.0.0/24 (matches docker-compose subnet) or nginx container IP
GITEA_TRUSTED_PROXIES=172.20.0.0/24

# =============================
# Security & auth
# =============================
GITEA_DISABLE_REGISTRATION=true

# Generate with: openssl rand -base64 48
GITEA_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_STRING

# Generate with: openssl rand -base64 64 | tr -d '\n'
GITEA_INTERNAL_TOKEN=REPLACE_WITH_LONG_RANDOM_STRING

# Generate with: openssl rand -base64 32
GITEA_JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# Generate with: openssl rand -base64 32
GITEA_LFS_JWT_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# =============================
# PostgreSQL
# =============================
POSTGRES_DB=gitea
POSTGRES_USER=gitea
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# =============================
# Redis
# =============================
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD
